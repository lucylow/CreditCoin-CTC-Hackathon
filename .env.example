# API mode: mock | dev | prod — mock uses local fallback, no network
VITE_API_MODE=mock

# PediScreen FastAPI backend (primary — run: make backend)
VITE_PEDISCREEN_BACKEND_URL=http://localhost:8000
VITE_MEDGEMMA_API_URL=http://localhost:8000/api
VITE_API_KEY=dev-example-key

# Demo vs Live: MOCK_MODE=true uses mock data when no MedGemma configured
MOCK_MODE=true

# MedGemma (set for live inference)
# HF_MODEL=google/medgemma-2b-it
# HF_API_KEY=your-hf-token
# VERTEX_PROJECT=your-project
# VERTEX_LOCATION=us-central1

# Orchestrator (multi-agent pipeline on port 7000)
# ORCHESTRATOR_PORT=7000
# EMBED_SERVER_URL=http://localhost:5000/embed

# Supabase (auth + Edge Functions) — required for Lovable Cloud
# Get from Supabase Dashboard > Project Settings > API
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Edge Functions (optional - when set, form submits use FormData + Supabase)
# VITE_SUPABASE_FUNCTION_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1

# AssemblyAI (voice-to-text for observations) — optional
# VITE_ASSEMBLYAI_KEY=your-assemblyai-api-key

# HITL WebSocket (real-time clinician dashboard)
# VITE_WS_URL=ws://localhost:5001

# Creditcoin EVM — RWA screening certificates (CTC gas; chain 336 mainnet / 337 testnet)
# No Polygon/Chainlink. Deploy: npx hardhat run scripts/deploy_rwa.js --network creditcoinTestnet
# VITE_CHAIN_ID=337
# VITE_CREDITCOIN_RPC_URL=https://testnet.creditcoin.network
# VITE_PEDISCREEN_NFT_ADDRESS=
# VITE_RISK_ENGINE_ADDRESS=
# VITE_CHW_REGISTRY_ADDRESS=
# VITE_PEDISC_TOKEN_ADDRESS=
# VITE_HEALTH_CHAIN_ADDRESS=
# RWA stack (Creditcoin USC: Attestor + DataFeed replace Chainlink)
# VITE_RWA_CONTRACT_ADDRESS=
# VITE_DATA_FEED_ADDRESS=
# Backend (mint/attest/data-feed; gas paid in CTC — keep key secret)
# CREDITCOIN_RPC=https://testnet.creditcoin.network
# CREDITCOIN_CHAIN_ID=337
# CTC_PRIVATE_KEY=0x...
# BACKEND_PRIVATE_KEY=0x...
# NFT_CONTRACT_ADDRESS=   # existing PediScreenNFT (optional)
# RISK_ENGINE_ADDRESS=
# CHW_REGISTRY_ADDRESS=
# PEDISC_TOKEN_ADDRESS=
# HEALTH_CHAIN_ADDRESS=
# RWA_CONTRACT_ADDRESS=   # PediScreenRWA (primary for /api/rwa)
# DATA_FEED_ADDRESS=     # external data oracle
# ATTESTATION_LOG_ADDRESS=
# Security (Creditcoin-native: consent + audit; no raw PHI on-chain)
# Deploy: npx hardhat run scripts/deploy_security.js --network creditcoinTestnet
# CONSENT_REGISTRY_ADDRESS=
# AUDIT_LOG_ADDRESS=
# EXCHANGE_RATE_API_KEY=  # optional; for /api/rwa/data-feed/refresh-exchange-rate

# Health Insurance Claims Payout (Creditcoin EVM)
# Deploy: npx hardhat run scripts/deploy_insurance.js --network creditcoinTestnet
# USDC_ADDRESS=           # MockUSDC (testnet) or real USDC (mainnet)
# INSURANCE_REGISTRY_ADDRESS=
# INSURANCE_PROCESSOR_ADDRESS=
# (Backend needs UNDERWRITER on PolicyRegistry and ATTESTOR on ClaimProcessor; deployer gets both)

# IPFS (Pinata) for screening report metadata
# PINATA_JWT=...
# PINATA_API_KEY=
# PINATA_SECRET_API_KEY=
# VITE_PINATA_API_KEY=
# VITE_PINATA_SECRET_KEY=

# Legacy / other chains (optional)
# VITE_PEDISCREEN_REGISTRY_ADDRESS=
# VITE_PAYMENT_ESCROW_ADDRESS=
# VITE_PEDISCREEN_RECORDS_ADDRESS=
# VITE_PEDISCREEN_ORACLE_ADDRESS=
# HealthChain POC — Base: VITE_HEALTH_CHAIN_POC_ADDRESS=, VITE_CHAIN_ID=84532
# Federated: VITE_FED_COORDINATOR_ADDRESS=, VITE_PEDI_REWARD_TOKEN_ADDRESS=

# Lovable: lovable.config.js at repo root; build output dist/; CI: .github/workflows/lovable.yml
# Optional: set VITE_BASE_URL (e.g. /app/) if the app is deployed under a subpath
# VITE_BASE_URL=/
